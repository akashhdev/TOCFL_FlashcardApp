# Copy this file to .env and fill in the values before running on the Pi.
# server/.env is gitignored — never commit the real file.

# A long random string used to sign JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Comma-separated list of allowed frontend origins (no trailing slash).
# Add your DuckDNS domain (or Pi LAN IP) here.
# Example: https://yourname.duckdns.org,http://192.168.1.50
ALLOWED_ORIGINS=https://yourname.duckdns.org

# Express port (default 3001)
PORT=3001
