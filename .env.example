# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit the real file.

# Google Gemini API key (used at build time — baked into the JS bundle).
# WARNING: this key will be visible in the compiled frontend.
# For a public deployment, leave this blank and have users enter their own key
# in the app Settings modal instead.
VITE_GEMINI_API_KEY=
